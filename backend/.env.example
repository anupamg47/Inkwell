# ==============================================================================
# PRODUCTION / DEPLOYMENT ENVIRONMENT VARIABLES (.env)
# ==============================================================================
# Copy this file to '.env' on PythonAnywhere and adjust values for production:
# cp .env.example .env
# ==============================================================================

# CRITICAL FOR PRODUCTION: Must be set to False on PythonAnywhere!
DEBUG=False

# Generate a strong, secret random key in production!
SECRET_KEY=replace-with-a-secure-random-secret-key-in-production

# ALLOWED_HOSTS: Authorizes all domains and PythonAnywhere subdomains
ALLOWED_HOSTS=*

