# ==============================================================================
# PRODUCTION / DEPLOYMENT ENVIRONMENT VARIABLES (.env)
# ==============================================================================
# Copy this file to '.env' on PythonAnywhere and adjust values for production:
# cp .env.example .env
# ==============================================================================

# CRITICAL FOR PRODUCTION: Must be set to False on PythonAnywhere!
DEBUG=False

# Generate a strong, secret random key in production!
SECRET_KEY=replace-with-a-secure-random-secret-key-in-production

# ALLOWED_HOSTS: Add your PythonAnywhere domain
ALLOWED_HOSTS=yourusername.pythonanywhere.com,localhost,127.0.0.1

# DATABASE CONFIGURATION:
# By default on PythonAnywhere, if you are on a free account without PostgreSQL,
# set DB_ENGINE=django.db.backends.sqlite3 to use SQLite automatically!
DB_ENGINE=django.db.backends.postgresql
DB_NAME=notesapp
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_HOST=localhost
DB_PORT=5432
